# This file is used for Git repositories to specify intentionally untracked files that Git should ignore. 
# If you are not using git, you can delete this file. For more information see: https://git-scm.com/docs/gitignore
# For useful gitignore templates see: https://github.com/github/gitignore

# Salesforce cache
.sfdx/
.localdevserver/
.sf/

# VS Code cache
.vscode/

# LWC VSCode autocomplete
**/lwc/jsconfig.json

# LWC Jest coverage reports
coverage/

# E2E – compiled UTAM page objects (generated; do not commit)
e2e-tests/__utam__/

# E2E – persistent Chrome profile (cookies + Salesforce device-trust marker
# live here; do not commit, would leak session credentials)
e2e-tests/.chrome-profile/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
node_modules/

# Eslint cache
.eslintcache

# npm lock file (not committed in this project)
package-lock.json

# Environment / secrets
.env
.env.*

# JetBrains IDEs
.idea/

# Vim swap files
*.swp
*.swo

# MacOS system files
.DS_Store

# Windows system files
Thumbs.db
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/
