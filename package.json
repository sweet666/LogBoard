{
  "name": "salesforce-app",
  "private": true,
  "version": "1.0.0",
  "description": "Salesforce App",
  "scripts": {
    "lint": "npm run lint:lwc",
    "lint:lwc": "eslint force-app/main/default/lwc",
    "test": "npm run test:unit",
    "test:unit": "NODE_OPTIONS=--unhandled-rejections=warn node_modules/@salesforce/sfdx-lwc-jest/node_modules/.bin/jest --no-coverage --config jest-config/jest.config.js",
    "test:unit:watch": "NODE_OPTIONS=--unhandled-rejections=warn node_modules/@salesforce/sfdx-lwc-jest/node_modules/.bin/jest --watch --config jest-config/jest.config.js",
    "test:unit:coverage": "NODE_OPTIONS=--unhandled-rejections=warn node_modules/@salesforce/sfdx-lwc-jest/node_modules/.bin/jest --coverage --config jest-config/jest.config.js",
    "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "prettier:verify": "prettier --list-different \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "test:e2e": "cd e2e-tests && npm run test:e2e",
    "test:e2e:headless": "cd e2e-tests && npm run test:e2e:headless"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^0.7.2",
    "@salesforce/eslint-config-lwc": "^0.5.0",
    "@salesforce/sfdx-lwc-jest": "^0.7.1",
    "eslint": "^6.8.0",
    "prettier": "^2.0.5",
    "prettier-plugin-apex": "^1.4.0"
  }
}